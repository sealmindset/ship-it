{
  "name": "ship-it-action",
  "version": "1.0.0",
  "description": "Guided delivery skill that helps new developers ship code to production through simple yes/no questions.",
  "main": "src/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "package": "npm run build && npm test",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ship-it-action"
  },
  "keywords": [
    "github-action",
    "devops",
    "ci-cd",
    "deployment",
    "developer-experience",
    "ship-it",
    "beginner-friendly"
  ],
  "author": "DevOps_Skills",
  "license": "MIT",
  "overrides": {
    "undici": "^6.24.1"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@actions/http-client": "^2.2.3",
    "@actions/io": "^1.1.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  }
}
